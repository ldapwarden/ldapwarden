# Organizational Units
dn: ou=People,dc=example,dc=org
objectClass: organizationalUnit
ou: People
description: User accounts

dn: ou=Groups,dc=example,dc=org
objectClass: organizationalUnit
ou: Groups
description: Group definitions

dn: ou=sudoers,dc=example,dc=org
objectClass: organizationalUnit
ou: sudoers
description: Sudo role definitions

dn: ou=policies,dc=example,dc=org
objectClass: organizationalUnit
ou: policies
description: Password policies

# Password Policies
dn: cn=default,ou=policies,dc=example,dc=org
objectClass: pwdPolicy
objectClass: person
objectClass: top
cn: default
sn: default
description: Default password policy
pwdAttribute: 2.5.4.35
pwdMinAge: 0
pwdMaxAge: 7776000
pwdInHistory: 5
pwdCheckQuality: 1
pwdMinLength: 8
pwdExpireWarning: 604800
pwdGraceAuthNLimit: 3
pwdLockout: TRUE
pwdLockoutDuration: 1800
pwdMaxFailure: 5
pwdFailureCountInterval: 900
pwdMustChange: FALSE
pwdAllowUserChange: TRUE
pwdSafeModify: FALSE

dn: cn=strict,ou=policies,dc=example,dc=org
objectClass: pwdPolicy
objectClass: person
objectClass: top
cn: strict
sn: strict
description: Strict password policy for privileged accounts
pwdAttribute: 2.5.4.35
pwdMinAge: 86400
pwdMaxAge: 2592000
pwdInHistory: 10
pwdCheckQuality: 2
pwdMinLength: 12
pwdExpireWarning: 1209600
pwdGraceAuthNLimit: 0
pwdLockout: TRUE
pwdLockoutDuration: 3600
pwdMaxFailure: 3
pwdFailureCountInterval: 600
pwdMustChange: TRUE
pwdAllowUserChange: TRUE
pwdSafeModify: TRUE

# Groups
dn: cn=admins,ou=Groups,dc=example,dc=org
objectClass: posixGroup
cn: admins
gidNumber: 1000
description: System administrators
memberUid: admin
memberUid: jdoe

dn: cn=developers,ou=Groups,dc=example,dc=org
objectClass: posixGroup
cn: developers
gidNumber: 1001
description: Development team
memberUid: jdoe
memberUid: asmith
memberUid: mjohnson

dn: cn=readonly,ou=Groups,dc=example,dc=org
objectClass: posixGroup
cn: readonly
gidNumber: 1002
description: Read-only users
memberUid: viewer

