# Sudo Roles
dn: cn=admins-sudo,ou=sudoers,dc=example,dc=org
objectClass: sudoRole
cn: admins-sudo
description: Full sudo access for admins
sudoUser: admin
sudoHost: ALL
sudoCommand: ALL
sudoRunAsUser: ALL
sudoRunAsGroup: ALL
sudoOption: !authenticate
sudoOrder: 100

dn: cn=dev-restart,ou=sudoers,dc=example,dc=org
objectClass: sudoRole
cn: dev-restart
description: Allow developers to restart services
sudoUser: jdoe
sudoUser: asmith
sudoUser: mjohnson
sudoHost: ALL
sudoCommand: /usr/bin/systemctl restart *
sudoCommand: /usr/bin/systemctl status *
sudoRunAsUser: root
sudoOrder: 50

dn: cn=package-updates,ou=sudoers,dc=example,dc=org
objectClass: sudoRole
cn: package-updates
description: Allow package management
sudoUser: admin
sudoUser: jdoe
sudoHost: ALL
sudoCommand: /usr/bin/apt update
sudoCommand: /usr/bin/apt upgrade
sudoCommand: /usr/bin/apt install *
sudoRunAsUser: root
sudoOption: !authenticate
sudoOrder: 75

dn: cn=developers-docker,ou=sudoers,dc=example,dc=org
objectClass: sudoRole
cn: developers-docker
description: Allow developers group to run docker commands
sudoUser: %developers
sudoHost: ALL
sudoCommand: /usr/bin/docker *
sudoRunAsUser: root
sudoOrder: 60
