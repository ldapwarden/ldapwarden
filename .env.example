# ==============================================================================
# LDAP Warden — example configuration
#
# Copy to .env and adjust to your environment. All values shown are the
# in-code defaults; commented lines indicate optional variables that are
# disabled when unset. See README.md for the full reference.
# ==============================================================================

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ------------------------------------------------------------------------------
# Database & Redis
# Default ports match the docker-compose stack.
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://ldapwarden:ldapwarden@localhost:5432/ldapwarden?sslmode=disable
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# LDAP
# ------------------------------------------------------------------------------
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=org
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_BIND_PASS=admin
LDAP_USER_OU=ou=People
LDAP_GROUP_OU=ou=Groups
LDAP_SUDOERS_OU=ou=sudoers
LDAP_PPOLICY_OU=ou=policies
LDAP_MIN_UID=1000
LDAP_MIN_GID=1000
# Max entries returned by the UI list/search endpoints. Larger result sets are
# truncated (the UI then prompts to refine the search). 0 disables the bound.
LDAP_SEARCH_SIZE_LIMIT=500
# TLS mode: none | ssl | starttls
LDAP_TLS_MODE=none
LDAP_TLS_SKIP_VERIFY=false

# ------------------------------------------------------------------------------
# Session
# SESSION_SECRET MUST be changed in production — used to sign session tokens.
# ------------------------------------------------------------------------------
SESSION_SECRET=change-me-in-production-32bytes!
SESSION_TTL=24h

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
LDAPWARDEN_ADMIN_GROUP=admins
LDAPWARDEN_ORGANIZATION=Example Organization
LDAPWARDEN_PUBLIC_URL=http://localhost:8000

# Comma-separated list of high-level navigation modules.
# Available: users, groups, sudo, policies
LDAPWARDEN_MODULES=users,groups,sudo,policies

# Comma-separated LDAP objectClasses for users / groups (drives which UI tabs
# are visible). See the "Module Configuration" section in README.md.
LDAPWARDEN_USERS_OBJECTS=inetOrgPerson,posixAccount,ldapPublicKey,shadowAccount
LDAPWARDEN_GROUPS_OBJECTS=posixGroup

# Recipients that receive an email for every UI modification (audit /
# traceability). Comma-separated. Empty or unset disables the feature.
# Requires a working SMTP configuration (see Mail section below).
#LDAPWARDEN_AUDIT_NOTIFY_EMAILS=secops@example.org,it-audit@example.org

# CIDRs of reverse proxies allowed to set X-Forwarded-For / X-Real-IP /
# True-Client-IP. Empty (default) means forwarded headers are NOT honoured —
# the connection peer is used instead. Set this when running behind nginx,
# Traefik, Caddy, AWS ALB, etc., otherwise audit logs will record the proxy
# IP rather than the actual client. Server refuses to start on bad CIDR.
#LDAPWARDEN_TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1/32

# Origins allowed by the CORS middleware. The API serves credentialed
# requests (Authorization header + cookies in the future), so "*" is
# refused at startup; list every front-end origin explicitly. Default
# covers the bundled `pnpm dev` server.
#LDAPWARDEN_CORS_ORIGINS=https://ldap.example.org

# Bypass production-secrets validation. The server normally refuses to start
# with the in-repo default SESSION_SECRET, LDAP_BIND_PASS=admin, or a plain
# http:// LDAPWARDEN_PUBLIC_URL. Only set this for the bundled docker-compose
# stack or local tests — never in a real deployment.
#LDAPWARDEN_DEV_MODE=1

# ------------------------------------------------------------------------------
# Mail (SMTP)
# Defaults target a local Mailpit / MailHog instance shipped with the stack.
# ------------------------------------------------------------------------------
MAIL_HOST=localhost
MAIL_PORT=1025
#MAIL_USER=
#MAIL_PASSWORD=
MAIL_FROM=noreply@example.org
# SSL mode: none | starttls | ssl
MAIL_SSL=none

# ------------------------------------------------------------------------------
# Scheduled tasks
# Cron expressions (5 fields). Set to an empty string to disable a task.
# ------------------------------------------------------------------------------
LDAPWARDEN_SCHEDULED_TASKS_USERS_EXPIRATION=42 3 * * *
LDAPWARDEN_SCHEDULED_TASKS_PASSWORDS_EXPIRATION=42 3 * * *
